# ============================================
# Bioinformatics Hub - Environment Variables
# ============================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha os valores conforme seu ambiente
# 3. NUNCA commite o arquivo .env!
#
# cp .env.example .env

# ============================================
# GERAL
# ============================================
APP_NAME=Bioinformatics Hub
DEBUG=true

# Gere uma chave segura com: openssl rand -hex 32
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-openssl-rand-hex-32

# ============================================
# DATABASE - PostgreSQL
# ============================================
# Para desenvolvimento local (docker-compose)
DATABASE_URL=postgresql+asyncpg://biohub:biohub123@localhost:5432/biohub

# Para produção (exemplo com Supabase/Neon/etc)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================
# NEO4J - Banco de Grafos
# ============================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=biohub123

# ============================================
# CORS - Origens Permitidas
# ============================================
# Separadas por vírgula para múltiplas origens
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# EXTERNAL APIS
# ============================================

# NCBI - Aumenta rate limit de 3 para 10 requests/segundo
# Obtenha em: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
NCBI_EMAIL=seu_email@exemplo.com

# UniProt
UNIPROT_BASE_URL=https://rest.uniprot.org

# ============================================
# FILE STORAGE
# ============================================
UPLOAD_DIR=./uploads
RESULTS_DIR=./results
MAX_UPLOAD_SIZE=104857600  # 100 MB em bytes

# ============================================
# BIOINFORMATICS TOOLS (caminhos locais)
# ============================================
# Preencha se tiver ferramentas instaladas localmente
# BLAST_PATH=/usr/local/bin
# DIAMOND_PATH=/usr/local/bin
# SIGNALP_PATH=/opt/signalp-6.0
